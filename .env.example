# ===== LLM API (OpenAI-compatible) =====
# Phial calls any LLM exposed in OpenAI SDK format to generate / edit HTML documents.
# Examples:
#   OpenAI:      LLM_BASE_URL=https://api.openai.com/v1            LLM_MODEL_NAME=gpt-4o
#   DeepSeek:    LLM_BASE_URL=https://api.deepseek.com/v1          LLM_MODEL_NAME=deepseek-chat
#   Qwen(Bailian): LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1   LLM_MODEL_NAME=qwen-plus
LLM_API_KEY=sk-603f67e9382f49afee0a0b580fc7dff313a74793f726ac26de95795b705dc5d9
LLM_BASE_URL=https://cc-vibe.com/v1
LLM_MODEL_NAME=gpt-5.5
# Max completion tokens per generation. Interactive HTML can get large; raise if
# your model supports it. Lower it if the API rejects the request.
# LLM_MAX_TOKENS=8192

# ===== Workspace =====
# Folder that holds your .html documents. Defaults to ~/PhialDocs if unset.
# PHIAL_WORKSPACE=/absolute/path/to/your/docs

# ===== Backend server =====
# FLASK_HOST=0.0.0.0
# FLASK_PORT=5001
# FLASK_DEBUG=True
# SECRET_KEY=change-me
